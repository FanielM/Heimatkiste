<div class="toast" id="toast"></div>

<script>
/* ══════════════════════════════
   SHARED DATA
══════════════════════════════ */
const DEFAULT_PRODUCTS = [
  {id:'d1',name:'Bio-Äpfel Elstar',farm:'Obsthof Meyer',cat:'Obst',price:2.80,unit:'1 kg',badge:'bio',img:'https://images.unsplash.com/photo-1560806887-1e4cd0b6bcd6?w=600&q=80',desc:'Knackige Bio-Äpfel aus der Region. Frisch vom Baum, frei von Pestiziden.'},
  {id:'d2',name:'Erdbeeren',farm:'Hof Metzger',cat:'Obst',price:3.49,unit:'500g',badge:'bio',img:'https://images.unsplash.com/photo-1464965911861-746a04b4bca6?w=600&q=80',desc:'Süße Erdbeeren direkt vom Feld. Im Sommer täglich frisch gepflückt.'},
  {id:'d3',name:'Bunte Karotten',farm:'Gemüsebau Lang',cat:'Gemüse',price:1.90,unit:'500g',badge:'regional',img:'https://images.unsplash.com/photo-1598170845058-32b9d6a5da37?w=600&q=80',desc:'Süße, knackige Karotten in verschiedenen Farben direkt vom Feld.'},
  {id:'d4',name:'Bunte Tomaten',farm:'Gärtnerei Schuster',cat:'Gemüse',price:2.90,unit:'500g',badge:'bio',img:'https://images.unsplash.com/photo-1546094096-0df4bcaaa337?w=600&q=80',desc:'Aromatische Tomaten in verschiedenen Sorten und Farben.'},
  {id:'d5',name:'Heumilch',farm:'Hof Sonnenschein',cat:'Milchprodukte',price:1.45,unit:'1 L',badge:'regional',img:'https://images.unsplash.com/photo-1550583724-125581f77833?w=600&q=80',desc:'Frische Heumilch von glücklichen Kühen. Direkt vom Hof.'},
  {id:'d6',name:'Bergkäse',farm:'Sennerei Alm',cat:'Milchprodukte',price:5.80,unit:'250g',badge:'bio',img:'https://images.unsplash.com/photo-1486297678162-eb2a19b0a32d?w=600&q=80',desc:'Würziger Bergkäse aus traditioneller Almsennerei.'},
  {id:'d7',name:'Freiland-Eier',farm:'Geflügelhof Weber',cat:'Eier & Honig',price:3.90,unit:'10 Stk.',badge:'regional',img:'https://images.unsplash.com/photo-1582284540020-8acbe03f4924?w=600&q=80',desc:'Frische Freiland-Eier aus regionaler, artgerechter Haltung.'},
  {id:'d8',name:'Waldhonig',farm:'Imkerei Schmidt',cat:'Eier & Honig',price:6.50,unit:'500g',badge:'bio',img:'https://images.unsplash.com/photo-1587049352846-4a222e784d38?w=600&q=80',desc:'Naturbelassener Waldhonig aus nachhaltiger Imkerei.'},
];

const CATS_CONFIG = [
  {name:'Obst',img:'https://images.unsplash.com/photo-1610832958506-aa56368176cf?w=600&q=80'},
  {name:'Gemüse',img:'https://images.unsplash.com/photo-1597362868423-3b1ad00dc9bb?w=600&q=80'},
  {name:'Milchprodukte',img:'https://images.unsplash.com/photo-1550583724-b2692b85b150?w=600&q=80'},
  {name:'Eier & Honig',img:'https://images.unsplash.com/photo-1582284540020-8acbe03f4924?w=600&q=80'},
];

function getAllProducts() {
  const farmer = JSON.parse(localStorage.getItem('farmerProducts') || '[]')
    .map((p,i) => ({
      id:'f'+i, name:p.name||'Produkt', farm:p.farmer||'Lokaler Hof',
      cat:p.category||'Sonstiges', price:parseFloat(p.price)||0,
      unit:p.unit||'Stk.', badge:'farmer', img:p.img||'https://images.unsplash.com/photo-1535914254981-b5012eebbd15?w=600&q=80',
      desc:p.desc||''
    }));
  return [...DEFAULT_PRODUCTS, ...farmer];
}

/* ══════════════════════════════
   CART & FAVS STATE
══════════════════════════════ */
let cart = JSON.parse(localStorage.getItem('hk_cart') || '{}');
let favs = new Set(JSON.parse(localStorage.getItem('hk_favs') || '[]'));
let activeFilter = 'Alle';

const fmt = n => n.toFixed(2).replace('.',',') + ' €';

function saveState() {
  localStorage.setItem('hk_cart', JSON.stringify(cart));
  localStorage.setItem('hk_favs', JSON.stringify([...favs]));
}

/* ══════════════════════════════
   TOAST
══════════════════════════════ */
function toast(msg, icon='✓') {
  const t = document.getElementById('toast');
  t.innerHTML = `<span>${icon}</span> ${msg}`;
  t.classList.add('show');
  clearTimeout(t._t);
  t._t = setTimeout(() => t.classList.remove('show'), 2600);
}

/* ══════════════════════════════
   CATEGORIES
══════════════════════════════ */
function renderCats() {
  const all = getAllProducts();
  const grid = document.getElementById('catsGrid');
  grid.innerHTML = '';
  CATS_CONFIG.forEach(c => {
    const count = all.filter(p => p.cat === c.name).length;
    grid.innerHTML += `
      <div class="cat-card" onclick="setFilter('${c.name}')">
        <img class="cat-img" src="${c.img}" alt="${c.name}" loading="lazy">
        <div class="cat-overlay"></div>
        <div class="cat-arrow">↗</div>
        <div class="cat-body"><h3>${c.name}</h3><div class="cat-count">${count} Produkte</div></div>
      </div>`;
  });
  const farmerCats = [...new Set(all.map(p=>p.cat))].filter(c => !CATS_CONFIG.find(x=>x.name===c));
  farmerCats.forEach(c => {
    const count = all.filter(p=>p.cat===c).length;
    grid.innerHTML += `
      <div class="cat-card" onclick="setFilter('${c}')" style="background:var(--straw)">
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:3rem;">🌾</div>
        <div class="cat-overlay"></div>
        <div class="cat-arrow">↗</div>
        <div class="cat-body"><h3>${c}</h3><div class="cat-count">${count} Produkte</div></div>
      </div>`;
  });
  grid.innerHTML += `
    <div class="cat-all" onclick="setFilter('Alle')">
      <div class="cat-all-icon">🌾</div>
      <h3>Alle zeigen</h3>
      <span>${all.length} Produkte</span>
    </div>`;
}

/* ══════════════════════════════
   FILTER TABS
══════════════════════════════ */
function renderFilterTabs() {
  const all = getAllProducts();
  const cats = ['Alle', ...new Set(all.map(p=>p.cat))];
  document.getElementById('filterTabs').innerHTML = cats.map(c =>
    `<button class="filter-tab ${c===activeFilter?'active':''}" onclick="setFilter('${c}')">${c}</button>`
  ).join('');
}

function setFilter(cat) {
  activeFilter = cat;
  renderFilterTabs();
  renderProducts();
  if (cat !== 'Alle') {
    setTimeout(() => document.getElementById('produkte').scrollIntoView({behavior:'smooth',block:'start'}), 50);
  }
}

/* ══════════════════════════════
   PRODUCTS
══════════════════════════════ */
function renderProducts() {
  const all = getAllProducts();
  const filtered = activeFilter === 'Alle' ? all : all.filter(p => p.cat === activeFilter);
  const grid = document.getElementById('productsGrid');
  if (!filtered.length) {
    grid.innerHTML = `<div class="empty-state"><span>🔍</span><p>Keine Produkte in dieser Kategorie.</p></div>`;
    return;
  }
  grid.innerHTML = filtered.map(p => `
    <div class="prod-card reveal" onclick="goDetail('${p.id}')">
      <div class="prod-img-wrap">
        <img class="prod-img" src="${p.img}" alt="${p.name}" loading="lazy">
        <span class="prod-badge ${p.badge==='bio'?'bio':p.badge==='farmer'?'farmer-added':''}">${p.badge==='bio'?'🌿 Bio':p.badge==='farmer'?'🧑‍🌾 Neu':'📍 Regional'}</span>
        <button class="prod-fav ${favs.has(p.id)?'active':''}" onclick="toggleFav('${p.id}',event)">${favs.has(p.id)?'♥':'♡'}</button>
      </div>
      <div class="prod-body">
        <div class="prod-meta">${p.cat}</div>
        <div class="prod-name">${p.name}</div>
        <div class="prod-farm">von ${p.farm}</div>
        <div class="prod-footer">
          <div><div class="prod-price">${fmt(p.price)}</div><div class="prod-unit">pro ${p.unit}</div></div>
          <button class="add-btn" onclick="addToCart('${p.id}',event)" title="In die Kiste">+</button>
        </div>
      </div>
    </div>`).join('');
  grid.querySelectorAll('.reveal').forEach(el => observer.observe(el));
}

/* ══════════════════════════════
   DETAIL NAVIGATION
══════════════════════════════ */
function goDetail(id) {
  localStorage.setItem('hk_detail_id', id);
  window.location.href = 'heimatkiste-detail.html';
}

/* ══════════════════════════════
   CART LOGIC
══════════════════════════════ */
function addToCart(id, e) {
  if(e) e.stopPropagation();
  cart[id] = (cart[id]||0) + 1;
  saveState();
  updateCartBadge();
  const p = getAllProducts().find(x=>x.id===id);
  toast(`${p.name} zur Kiste hinzugefügt`, '🧺');
}
function changeQty(id, delta) {
  cart[id] = (cart[id]||0) + delta;
  if (cart[id] <= 0) delete cart[id];
  saveState();
  updateCartBadge();
  renderCartBody();
}
function removeCartItem(id) {
  delete cart[id];
  saveState();
  updateCartBadge();
  renderCartBody();
}
function updateCartBadge() {
  const total = Object.values(cart).reduce((a,b)=>a+b,0);
  const b = document.getElementById('cartBadge');
  b.textContent = total;
  b.classList.toggle('show', total > 0);
}
function renderCartBody() {
  const ids = Object.keys(cart);
  const body = document.getElementById('cartBody');
  const footer = document.getElementById('cartFooter');
  const all = getAllProducts();
  if (!ids.length) {
    body.innerHTML = `<div class="sidebar-empty"><span>🧺</span><p>Deine Kiste ist noch leer.</p></div>`;
    footer.style.display = 'none'; return;
  }
  footer.style.display = '';
  body.innerHTML = ids.map(id => {
    const p = all.find(x=>x.id===id) || {name:'Produkt',farm:'',img:'',price:0};
    return `
      <div class="cart-item-row">
        <img class="cart-item-img" src="${p.img}" alt="${p.name}">
        <div class="cart-item-info">
          <div class="cart-item-name">${p.name}</div>
          <div class="cart-item-farm">${p.farm}</div>
          <div class="cart-item-controls">
            <button class="qty-btn" onclick="changeQty('${id}',-1)">−</button>
            <span class="qty-val">${cart[id]}</span>
            <button class="qty-btn" onclick="changeQty('${id}',1)">+</button>
            <button class="cart-item-remove" onclick="removeCartItem('${id}')">✕</button>
          </div>
        </div>
        <div class="cart-item-price">${fmt(p.price*cart[id])}</div>
      </div>`;
  }).join('');
  const sum = ids.reduce((a,id)=>{const p=all.find(x=>x.id===id);return a+(p?p.price*cart[id]:0);},0);
  document.getElementById('subtotal').textContent = fmt(sum);
  document.getElementById('cartTotal').textContent = fmt(sum);
}

/* ══════════════════════════════
   FAVS LOGIC
══════════════════════════════ */
function toggleFav(id, e) {
  if(e) e.stopPropagation();
  if(favs.has(id)) { favs.delete(id); toast('Aus Favoriten entfernt','♡'); }
  else { favs.add(id); const p=getAllProducts().find(x=>x.id===id); toast(`${p.name} gemerkt`,'♥'); }
  saveState();
  updateFavBadge();
  renderProducts();
}
function updateFavBadge() {
  const b = document.getElementById('favBadge');
  b.textContent = favs.size;
  b.classList.toggle('show', favs.size > 0);
}
function renderFavBody() {
  const body = document.getElementById('favBody');
  const all = getAllProducts();
  if (!favs.size) {
    body.innerHTML = `<div class="sidebar-empty"><span>♡</span><p>Noch keine Favoriten gespeichert.</p></div>`;
    return;
  }
  body.innerHTML = [...favs].map(id => {
    const p = all.find(x=>x.id===id);
    if(!p) return '';
    return `
      <div class="fav-item-row">
        <img class="fav-item-img" src="${p.img}" alt="${p.name}">
        <div class="fav-item-info">
          <div class="fav-item-name">${p.name}</div>
          <div class="fav-item-price">${fmt(p.price)} · ${p.farm}</div>
        </div>
        <button class="fav-remove" onclick="toggleFav('${id}',event)">✕</button>
      </div>`;
  }).join('');
}

/* ══════════════════════════════
   SIDEBAR TOGGLES
══════════════════════════════ */
function openSidebar(sid,oid){document.getElementById(sid).classList.add('open');document.getElementById(oid).classList.add('show');document.body.style.overflow='hidden';}
function closeSidebar(sid,oid){document.getElementById(sid).classList.remove('open');document.getElementById(oid).classList.remove('show');document.body.style.overflow='';}
document.getElementById('cartBtn').onclick=()=>{renderCartBody();openSidebar('cartSidebar','cartOverlay');};
document.getElementById('cartClose').onclick=()=>closeSidebar('cartSidebar','cartOverlay');
document.getElementById('cartOverlay').onclick=()=>closeSidebar('cartSidebar','cartOverlay');
document.getElementById('favBtn').onclick=()=>{renderFavBody();openSidebar('favSidebar','favOverlay');};
document.getElementById('favClose').onclick=()=>closeSidebar('favSidebar','favOverlay');
document.getElementById('favOverlay').onclick=()=>closeSidebar('favSidebar','favOverlay');
document.getElementById('checkoutBtn').onclick=()=>{
  if(!Object.keys(cart).length){toast('Deine Kiste ist leer!','⚠️');return;}
  cart={};saveState();updateCartBadge();renderCartBody();closeSidebar('cartSidebar','cartOverlay');
  toast('Bestellung erfolgreich! Danke!','🎉');
};

/* ══════════════════════════════
   NAVBAR + REVEAL
══════════════════════════════ */
window.addEventListener('scroll',()=>document.getElementById('header').classList.toggle('scrolled',scrollY>40));
const observer=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis');}),{threshold:.1,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.reveal').forEach(el=>observer.observe(el));

/* ══════════════════════════════
   INIT
══════════════════════════════ */
renderCats();
renderFilterTabs();
renderProducts();
updateCartBadge();
updateFavBadge();
</script>
