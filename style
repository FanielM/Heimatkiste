    align-items: center;
    gap: 4px;
}

.favorites-icon i {
    font-size: 1.5rem;
    color: var(--text-dark);
    transition: 0.3s ease;
}

.favorites-icon:hover i {
    color: var(--green);
}

.favorites-icon span {
    position: absolute;
    top: -8px;
