    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 50%;
}
/* Animation für Produkte beim Hinzufügen */
@keyframes flyToCart {
    0% {
        transform: scale(1) translateY(0) rotate(0deg);
        opacity: 1;
    }
    50% {
        transform: scale(1.2) translateY(-20px) rotate(15deg);
        opacity: 0.8;
    }
    100% {
        transform: scale(0.5) translateY(-50px) rotate(30deg);
        opacity: 0;
    }
}

.cart-item-fly {
    position: absolute;
    z-index: 9999;
    pointer-events: none;
    animation: flyToCart 0.7s forwards;
}
