@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');

:root {
    --green: #3cb815;
    --orange: #f2994a;
    --text-dark: #0d1b1e;
    --text-light: #5a6b6d;
    --bg-color: #fdfcf8;
    --white: #ffffff;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
    text-decoration: none; /* Unterstriche weg */
}

body {
    background: var(--bg-color);
    color: var(--text-dark);
    overflow-x: hidden;
}

/* --- HEADER --- */
header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 10%;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    z-index: 1000;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.logo {
    display: flex;
    align-items: center;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-dark);
}
.logo i {
    color: var(--green);
    font-size: 1.8rem;
    margin-right: 8px;
}

.navbar {
    display: flex;
    gap: 2rem;
}
.navbar a {
    color: var(--text-dark);
    font-weight: 500;
}
.navbar a:hover { color: var(--green); }

.header-icons {
    display: flex;
    align-items: center;
    gap: 1rem;
}
.header-icons .btn-farmer {
    background: var(--green);
    color: var(--white);
    padding: 8px 20px;
    border-radius: 50px;
    font-weight: 600;
}
.header-icons .btn-farmer:hover { background: var(--orange); }
.profile i, #menu-icon, #cart-btn i { font-size: 24px; cursor: pointer; }
#menu-icon { display: none; }

/* --- HERO --- */
.home {
    padding-top: 120px;
}

.home .container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    padding: 0 5%;
}

.home-text {
    flex: 1 1 450px;
    max-width: 550px;
}

.home-img {
    flex: 1 1 450px;
    display: flex;
    justify-content: center;
}

.home-img img {
    max-width: 400px;
    width: 100%;
    border-radius: 20px;
}
.home-text span {
    display: inline-block;
    background: rgba(60,184,21,0.1);
    color: var(--green);
    padding: 5px 12px;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 10px;
}
.home-text h1 { font-size: clamp(2rem,5vw,3rem); margin: 15px 0; line-height: 1.2; }
.home-text p { color: var(--text-light); font-size: 1rem; margin-bottom: 20px; }
.home-btns a {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 50px;
    font-weight: 600;
    margin-right: 10px;
}
.home-btns .btn { background: var(--green); color: var(--white); }
.home-btns .btn:hover { background: var(--orange); }
.home-btns .btn-alt { background: #eee; color: var(--text-dark); }
.home-btns .btn-alt:hover { background: #ddd; }
.home-img { flex: 1; display: flex; justify-content: center; }
.home-img img { width: 100%; max-width: 450px; border-radius: 20px; object-fit: cover; }

/* --- FEATURES --- */
.features {
    display: flex;
    justify-content: space-around;
    text-align: center;
    padding: 50px 10%;
    flex-wrap: wrap;
    gap: 20px;
}
.feature-box {
    flex: 1;
    min-width: 220px;
    background: var(--white);
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
}
.feature-box i { font-size: 40px; color: var(--green); margin-bottom: 10px; }

/* --- CATEGORIES --- */
.categories { padding: 50px 10%; }
.categories .heading { text-align: center; margin-bottom: 25px; }
.categories .heading h1 { font-size: 1.8rem; font-weight: 700; }
/* KATEGORIEN */
.categories {
    padding: 60px 5%;
}

.categories-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
}

.categories-container .box {
    background: #fff;
    border-radius: 18px;
    padding: 15px;
    text-align: center;
    transition: 0.3s ease;
}

.categories-container .box:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.08);
}

.categories-container img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: 12px;
}
/* --- PRODUKTE --- */
.produkte { padding: 50px 10%; }
.produkte .heading { text-align: center; margin-bottom: 25px; position: relative; }
.produkte .heading h1 { font-size: 1.8rem; font-weight: 700; }
.produkte .heading span { color: var(--green); }
.produkte .heading::after {
    content: "";
    display: block;
    width: 60px;
    height: 4px;
    background: var(--green);
    margin: 8px auto 0 auto;
    border-radius: 2px;
}
/* PRODUKTE */
.produkte {
    padding: 60px 5%;
}

.produkte-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 25px;
}

.product-card {
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    overflow: hidden;
    transition: 0.3s ease;
}

.product-card:hover {
    transform: translateY(-6px);
}

.product-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
}

.product-info {
    padding: 15px;
}

.price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
}

.box-icons { display: flex; justify-content: center; gap: 15px; padding: 10px 0; }
.box-icons i { cursor: pointer; font-size: 22px; color: var(--green); }
.box-icons i:hover { color: var(--orange); }

/* --- ABOUT --- */
.about-container { display: flex; flex-wrap: wrap; justify-content: space-between; padding: 50px 10%; gap: 20px; }
.about-img, .about-text { flex: 1 1 400px; }
.about-img img { width: 100%; border-radius: 20px; object-fit: cover; }
.about-text h2 { font-size: 1.8rem; margin-bottom: 15px; }
.about-text p { margin-bottom: 15px; color: var(--text-light); }

/* --- FARMER JOIN --- */
.farmer-join { background: #f5f5f5; padding: 50px 10%; text-align: center; }
.join-form { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-top: 20px; }
.join-form input { padding: 12px; border-radius: 50px; border: 1px solid #ddd; min-width: 200px; }
.join-form button { padding: 12px 30px; border-radius: 50px; background: var(--green); color: #fff; font-weight: 600; border: none; cursor: pointer; }
.join-form button:hover { background: var(--orange); }

/* --- FOOTER --- */
footer { background: #222; color: #fff; padding: 30px 10%; }
footer a { color: #fff; }
footer .social a { margin-right: 10px; font-size: 20px; }
footer .footer-container { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 20px; }

/* --- WARENKORB SIDEBAR --- */
.cart-sidebar {
    position: fixed;
    right: -100%;
    top: 0;
    width: 300px;
    max-width: 90%;
    height: 100%;
    background: var(--white);
    box-shadow: -4px 0 20px rgba(0,0,0,0.1);
    transition: 0.4s;
    z-index: 2000;
    display: flex;
    flex-direction: column;
}
.cart-sidebar.active { right: 0; }
.cart-header { display: flex; justify-content: space-between; align-items: center; padding: 20px; border-bottom: 1px solid #eee; }
.cart-header h2 { font-weight: 800; font-size: 1.2rem; }
.cart-content { flex: 1; padding: 20px; overflow-y: auto; }
.cart-item { display: flex; justify-content: space-between; margin-bottom: 10px; }
.cart-footer { padding: 20px; border-top: 1px solid #eee; }
.cart-footer button { width: 100%; padding: 12px; border-radius: 50px; background: var(--green); color: #fff; font-weight: 600; border: none; cursor: pointer; }
.cart-footer button:hover { background: var(--orange); }

.cart-overlay {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.3);
    opacity: 0;
    visibility: hidden;
    transition: 0.4s;
    z-index: 1500;
}
.cart-overlay.active { opacity: 1; visibility: visible; }

/* --- RESPONSIVE --- */
@media (max-width: 1200px) { .produkte-container { grid-template-columns: repeat(4,1fr); } }
@media (max-width: 992px) { .produkte-container { grid-template-columns: repeat(3,1fr); } .categories-container { grid-template-columns: repeat(3,1fr); } }
@media (max-width: 768px) {
    #menu-icon { display: block; }
    .navbar { position: absolute; top: -1000%; left: 0; width: 100%; background: var(--white); flex-direction: column; padding: 40px; text-align: center; transition: 0.5s; }
    .navbar.active { top: 100%; }
    .home .container { flex-direction: column; text-align: center; padding-top: 140px; }
    .produkte-container { grid-template-columns: repeat(2,1fr); }
    .categories-container { grid-template-columns: repeat(2,1fr); }
}
@media (max-width: 480px) {
    .produkte-container, .categories-container { grid-template-columns: 1fr; }
}
@media (max-width: 768px) {
    .home .container {
        flex-direction: column;
        text-align: center;
        padding-top: 80px;
    }

    .home-text {
        margin-bottom: 30px;
    }

    .home-img img {
        max-width: 300px;
    }
}
