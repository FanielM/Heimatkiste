    color: #333;
    transition: color 0.3s, transform 0.2s;
}

.box-icons i:hover {
    color: #27ae60; /* grün beim hover */
    transform: scale(1.2);
}
/* ------------------------------
   HEART PULS ANIMATION
------------------------------ */
@keyframes pulse {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.3); }
    100% { transform: scale(1); }
}

.box-icons i.bx-heart.active {
    color: #e74c3c; /* Rot, wenn aktiviert */
    animation: pulse 0.3s ease;
}
